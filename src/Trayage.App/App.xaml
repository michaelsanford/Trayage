<Application x:Class="Trayage.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Trayage.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
            <local:InverseBooleanConverter x:Key="InverseBool" />
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <local:EmptyStringToCollapsedConverter x:Key="EmptyStringToCollapsed" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
