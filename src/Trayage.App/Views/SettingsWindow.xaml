<ui:FluentWindow x:Class="Trayage.App.Views.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Trayage Settings"
                 Width="640"
                 Height="600"
                 MinWidth="560"
                 MinHeight="480"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Trayage Settings" />

        <TabControl Grid.Row="1"
                    TabStripPlacement="Left"
                    Margin="12,4,12,12"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectionChanged="OnTabSelectionChanged">

            <!-- Accounts -->
            <TabItem Header="Accounts">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,8">
                    <StackPanel>
                        <TextBlock Text="Accounts" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <ui:CardControl Margin="0,0,0,12">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource GitHubMarkGeometry}"
                                          Fill="{DynamicResource TextFillColorPrimaryBrush}"
                                          Stretch="Uniform" Width="22" Height="22"
                                          VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="GitHub" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding GitHubAccountLabel}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="Connect"
                                           Appearance="Primary"
                                           Command="{Binding ConnectGitHubCommand}"
                                           IsEnabled="{Binding GitHubBusy, Converter={StaticResource InverseBool}}"
                                           Visibility="{Binding GitHubConnected, Converter={StaticResource InverseBoolToVisibility}}" />
                                <ui:Button Content="Disconnect"
                                           Command="{Binding DisconnectGitHubCommand}"
                                           Visibility="{Binding GitHubConnected, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </ui:CardControl>

                        <StackPanel Margin="4,0,0,16"
                                    Visibility="{Binding GitHubDeviceInstruction, Converter={StaticResource EmptyStringToCollapsed}}">
                            <TextBlock Text="{Binding GitHubDeviceInstruction}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,8,0,0"
                                        Visibility="{Binding GitHubUserCode, Converter={StaticResource EmptyStringToCollapsed}}">
                                <ui:TextBox Text="{Binding GitHubUserCode, Mode=OneWay}"
                                            IsReadOnly="True"
                                            FontFamily="Cascadia Mono, Consolas, monospace"
                                            FontSize="18"
                                            MinWidth="150"
                                            VerticalContentAlignment="Center" />
                                <ui:Button Content="Copy"
                                           Icon="{ui:SymbolIcon Copy24}"
                                           Margin="8,0,0,0"
                                           Command="{Binding CopyGitHubCodeCommand}" />
                            </StackPanel>
                        </StackPanel>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource BitbucketMarkGeometry}"
                                          Fill="{StaticResource BitbucketBlueBrush}"
                                          Stretch="Uniform" Width="22" Height="22"
                                          VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Bitbucket Cloud" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding BitbucketAccountLabel}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="Connect"
                                           Appearance="Primary"
                                           Command="{Binding ConnectBitbucketCommand}"
                                           IsEnabled="{Binding BitbucketBusy, Converter={StaticResource InverseBool}}"
                                           Visibility="{Binding BitbucketConnected, Converter={StaticResource InverseBoolToVisibility}}" />
                                <ui:Button Content="Disconnect"
                                           Command="{Binding DisconnectBitbucketCommand}"
                                           Visibility="{Binding BitbucketConnected, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </ui:CardControl>
                        <TextBlock Text="{Binding BitbucketStatus}"
                                   TextWrapping="Wrap"
                                   Margin="4,0,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Visibility="{Binding BitbucketStatus, Converter={StaticResource EmptyStringToCollapsed}}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Notifications -->
            <TabItem Header="Notifications">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,8">
                    <StackPanel>
                        <TextBlock Text="Notifications" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="Choose which kinds of activity raise a Windows toast."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Shown only when the OS can't deliver toasts (Windows App Runtime missing).
                             Trayage still tracks the inbox in the tray; this offers the one-click fix. -->
                        <StackPanel Margin="0,0,0,16"
                                    Visibility="{Binding ToastsUnavailable, Converter={StaticResource BoolToVisibility}}">
                            <ui:InfoBar Severity="Warning"
                                        IsOpen="True"
                                        IsClosable="False"
                                        Title="Notifications unavailable"
                                        Message="Windows toasts need the Windows App Runtime, which isn't installed on this PC. Trayage still tracks your inbox from the tray — install the runtime to turn on pop-up notifications, then reopen Settings." />
                            <ui:Button Content="Get the Windows App Runtime"
                                       Icon="{ui:SymbolIcon ArrowDownload24}"
                                       Margin="0,8,0,0"
                                       Command="{Binding OpenNotificationRuntimeHelpCommand}" />
                        </StackPanel>

                        <ui:ToggleSwitch Content="Review requests"
                                         IsChecked="{Binding NotifyReviewRequests}"
                                         Margin="0,0,0,10" />
                        <ui:ToggleSwitch Content="Mentions and assignments"
                                         IsChecked="{Binding NotifyMentions}"
                                         Margin="0,0,0,10" />
                        <ui:ToggleSwitch Content="CI / check status changes"
                                         IsChecked="{Binding NotifyCi}"
                                         Margin="0,0,0,10" />
                        <ui:ToggleSwitch Content="All activity on watched repositories"
                                         IsChecked="{Binding NotifyWatchedRepoActivity}"
                                         Margin="0,0,0,10" />
                        <ui:ToggleSwitch Content="Issues &amp; PRs I'm involved in"
                                         IsChecked="{Binding NotifyParticipating}"
                                         Margin="0,0,0,10" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Bitbucket: watched-repo picker. Bitbucket has no notification inbox, so the
                 repos chosen here are the ones Trayage actively queries for activity. -->
            <TabItem Header="Bitbucket" x:Name="BitbucketTab">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,8">
                    <StackPanel>
                        <TextBlock Text="Bitbucket repositories" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="Bitbucket has no notification inbox, so Trayage watches the repositories you pick here — surfacing their pull requests, review requests, and activity. Load your repositories and toggle the ones you care about. (Whether watched-repo activity also raises a toast is set on the Notifications tab.)"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,16" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0"
                                       Content="Refresh"
                                       Icon="{ui:SymbolIcon ArrowSync24}"
                                       ToolTip="Reload your accessible Bitbucket repositories"
                                       Appearance="Primary"
                                       IsEnabled="{Binding BitbucketConnected}"
                                       Command="{Binding LoadBitbucketReposCommand}"
                                       Margin="0,0,8,0" />
                            <ui:TextBox Grid.Column="1"
                                        PlaceholderText="Filter…"
                                        Text="{Binding RepoFilter, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <TextBlock Text="{Binding RepoLoadStatus}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding RepoLoadStatus, Converter={StaticResource EmptyStringToCollapsed}}" />

                        <!-- Grouped into collapsible workspace sections (CollectionView grouping). -->
                        <ItemsControl ItemsSource="{Binding BitbucketRepoView}" Margin="0,0,0,16">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="{x:Type GroupItem}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                        <!-- Collapsed by default so large accounts aren't a wall of repos;
                                                             a typed filter auto-expands groups so matches are visible. -->
                                                        <Expander Margin="0,0,0,4"
                                                                  IsExpanded="{Binding DataContext.RepoFilterActive, RelativeSource={RelativeSource AncestorType=ItemsControl}, Mode=OneWay}">
                                                            <Expander.Header>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                </StackPanel>
                                                            </Expander.Header>
                                                            <ItemsPresenter Margin="12,4,0,4" />
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Compact one-line row (workspace is already the group header),
                                         so large accounts list densely instead of a wall of cards. -->
                                    <Grid Margin="0,3,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FullName}" />
                                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding IsWatched}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Add a repository manually" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="For a repository the loader can't reach. It's added to the watched list above (toggle it off there to stop watching)."
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        PlaceholderText="owner/repo or a Bitbucket URL"
                                        Text="{Binding NewWatchedRepo, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="0,0,8,0" />
                            <ui:Button Grid.Column="1"
                                       Content="Add"
                                       Appearance="Secondary"
                                       Command="{Binding AddWatchedRepoCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding WatchedRepoError}"
                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"
                                   Visibility="{Binding WatchedRepoError, Converter={StaticResource EmptyStringToCollapsed}}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- GitHub: informational. GitHub watching/notifications are managed on GitHub;
                 Trayage only mirrors the resulting notifications inbox. -->
            <TabItem Header="GitHub">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,8">
                    <StackPanel>
                        <TextBlock Text="GitHub repositories" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="Your GitHub items mirror your GitHub notifications inbox. To choose which repositories notify you, manage watching and notification preferences on GitHub itself — Trayage shows whatever GitHub delivers."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,16" />

                        <ui:HyperlinkButton Content="Open your GitHub notifications inbox"
                                            NavigateUri="https://github.com/notifications"
                                            Margin="0,0,0,4" />
                        <ui:HyperlinkButton Content="Manage which repositories you watch"
                                            NavigateUri="https://github.com/watching"
                                            Margin="0,0,0,4" />
                        <ui:HyperlinkButton Content="GitHub notification settings"
                                            NavigateUri="https://github.com/settings/notifications"
                                            Margin="0,0,0,16" />

                        <TextBlock Text="Trayage can only escalate notifications GitHub already sends into Windows toasts (see the Notifications tab); it can't surface activity GitHub isn't notifying you about."
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- General -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,8">
                    <StackPanel>
                        <TextBlock Text="General" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <ui:CardControl Margin="0,0,0,12">
                            <ui:CardControl.Header>
                                <TextBlock Text="Check for new activity every" VerticalAlignment="Center" />
                            </ui:CardControl.Header>
                            <ComboBox ItemsSource="{Binding PollIntervalOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Seconds"
                                      SelectedValue="{Binding PollIntervalSeconds}"
                                      MinWidth="120" />
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,12">
                            <ui:CardControl.Header>
                                <TextBlock Text="Theme" VerticalAlignment="Center" />
                            </ui:CardControl.Header>
                            <ComboBox ItemsSource="{Binding Themes}"
                                      SelectedItem="{Binding SelectedTheme}"
                                      MinWidth="120" />
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,12">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Group by repository" FontWeight="SemiBold" />
                                    <TextBlock Text="Group inbox items under each repository. Off shows a single newest-first list."
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:ToggleSwitch IsChecked="{Binding GroupByRepository}" />
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,12">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Show read items" FontWeight="SemiBold" />
                                    <TextBlock Text="Keep already-read items in the inbox (dimmed). Off shows only unread items."
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:ToggleSwitch IsChecked="{Binding ShowReadItems}" />
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,12">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Surface recently-modified items" FontWeight="SemiBold" />
                                    <TextBlock Text="Show and notify on recently-updated items even if GitHub already marks them read (within ~2× the poll interval)."
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:ToggleSwitch IsChecked="{Binding SurfaceRecentlyModified}" />
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,12">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Start with Windows" FontWeight="SemiBold" />
                                    <TextBlock Text="Launch Trayage automatically when you sign in."
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:ToggleSwitch IsChecked="{Binding StartWithWindows}" />
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,12">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Verbose logging" FontWeight="SemiBold" />
                                    <TextBlock Text="Capture detailed (debug) logs for bug reports. Applies after restart."
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:ToggleSwitch IsChecked="{Binding VerboseLogging}" />
                        </ui:CardControl>

                        <ui:CardControl>
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Diagnostic logs" FontWeight="SemiBold" />
                                    <TextBlock Text="Stored locally; contain no account names or tokens, so they're safe to attach to a bug report."
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:Button Content="Open logs folder"
                                       Icon="{ui:SymbolIcon FolderOpen24}"
                                       Command="{Binding OpenLogsCommand}" />
                        </ui:CardControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>
