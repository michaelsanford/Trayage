<Window x:Class="Trayage.App.Views.InboxFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Trayage.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:InboxViewModel, IsDesignTimeCreatable=False}"
        Title="Trayage Inbox"
        Width="400"
        Height="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- Flat, rounded row that highlights subtly on hover (mirrors the docs .item). -->
        <Style x:Key="RowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Inbox"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <ui:Button Appearance="Secondary"
                               Icon="{ui:SymbolIcon ArrowSync24}"
                               ToolTip="Refresh"
                               AutomationProperties.Name="Refresh inbox"
                               Command="{Binding RefreshCommand}"
                               Margin="0,0,8,0" />
                    <ui:Button Appearance="Secondary"
                               Icon="{ui:SymbolIcon Settings24}"
                               ToolTip="Settings"
                               AutomationProperties.Name="Open settings"
                               Command="{Binding OpenSettingsCommand}" />
                </StackPanel>
            </Grid>

            <!-- Items -->
            <!-- Empty / caught-up state. -->
            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <ui:SymbolIcon Symbol="CheckmarkCircle24"
                               FontSize="40"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="You're all caught up."
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <ListView Grid.Row="1"
                      ItemsSource="{Binding ItemsView}"
                      Background="Transparent"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                      VirtualizingPanel.ScrollUnit="Pixel">
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate DataType="{x:Type CollectionViewGroup}">
                                <TextBlock Text="{Binding Name}"
                                           FontFamily="Cascadia Mono, Consolas, monospace"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="6,12,0,4"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,1" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:InboxItemViewModel}">
                        <Button Style="{StaticResource RowButton}"
                                Command="{Binding DataContext.OpenItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                CommandParameter="{Binding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Kind + provider badge: a filled shape coloured by provider
                                     (neutral = GitHub, blue = Bitbucket) holds contrast in both
                                     themes and encodes the source; the glyph shows the kind, and a
                                     small corner mark carries the actual provider logo. -->
                                <Grid Grid.Column="0"
                                      Width="28" Height="28"
                                      Margin="0,1,10,0"
                                      VerticalAlignment="Top">
                                    <Border CornerRadius="7">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Provider}" Value="Bitbucket">
                                                        <Setter Property="Background" Value="{StaticResource BitbucketBlueBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Provider}" Value="GitLab">
                                                        <Setter Property="Background" Value="{StaticResource GitLabOrangeBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ui:SymbolIcon Symbol="{Binding KindIcon}" FontSize="14">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="{x:Type ui:SymbolIcon}">
                                                    <Setter Property="Foreground" Value="{DynamicResource ApplicationBackgroundBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Provider}" Value="Bitbucket">
                                                            <Setter Property="Foreground" Value="{StaticResource ProviderBadgeGlyphBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Provider}" Value="GitLab">
                                                            <Setter Property="Foreground" Value="{StaticResource ProviderBadgeGlyphBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                    </Border>

                                    <!-- Corner provider chip (real brand mark). -->
                                    <Border Width="14" Height="14" CornerRadius="7"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,-3,-3"
                                            Background="{DynamicResource ApplicationBackgroundBrush}">
                                        <Path Stretch="Uniform" Width="9" Height="9"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Data" Value="{StaticResource GitHubMarkGeometry}" />
                                                    <Setter Property="Fill" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Provider}" Value="Bitbucket">
                                                            <Setter Property="Data" Value="{StaticResource BitbucketMarkGeometry}" />
                                                            <Setter Property="Fill" Value="{StaticResource BitbucketBlueBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Provider}" Value="GitLab">
                                                            <Setter Property="Data" Value="{StaticResource GitLabMarkGeometry}" />
                                                            <Setter Property="Fill" Value="{StaticResource GitLabOrangeBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Border>
                                </Grid>

                                <!-- Title + subtitle -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <Style.Triggers>
                                                    <!-- Read items are de-emphasised. -->
                                                    <DataTrigger Binding="{Binding IsUnread}" Value="False">
                                                        <Setter Property="FontWeight" Value="Normal" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Subtitle}"
                                               FontSize="11"
                                               Margin="0,2,0,0"
                                               FontFamily="Cascadia Mono, Consolas, monospace"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                                <!-- Unread dot -->
                                <Ellipse Grid.Column="2"
                                         Width="9" Height="9"
                                         Fill="{StaticResource TrayageUnreadBrush}"
                                         VerticalAlignment="Center"
                                         Margin="10,0,2,0"
                                         Visibility="{Binding IsUnread, Converter={StaticResource BoolToVisibility}}">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#E5484D" BlurRadius="10" ShadowDepth="0" Opacity="0.7" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Refresh affordance: a slim indeterminate bar pinned to the top of the list,
                 so an in-flight refresh never blanks the items already shown. -->
            <ProgressBar Grid.Row="1"
                         IsIndeterminate="True"
                         Height="2"
                         VerticalAlignment="Top"
                         Background="Transparent"
                         BorderThickness="0"
                         Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVisibility}}" />

            <!-- Footer -->
            <TextBlock Grid.Row="2"
                       Text="{Binding StatusText}"
                       Margin="4,12,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Grid>
    </Border>
</Window>
